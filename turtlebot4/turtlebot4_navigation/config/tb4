#!/usr/bin/env bash
set -e

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || {
    echo "Error: required command '$1' not found."
    exit 1
  }
}

deg_to_rad() {
  echo "$1 * 3.141592653589793 / 180" | bc -l
}

usage() {
  cat <<'EOF'
Usage:
  tb4 undock
  tb4 dock
  tb4 fwd [distance_m] [speed_mps]
  tb4 back [distance_m] [speed_mps]
  tb4 turn [degrees] [max_rotation_speed]
  tb4 stop
  tb4 stop svc
  tb4 estop on|off
  tb4 start svc
  tb4 restart
  tb4 reboot create3
  tb4 status
  tb4 login
  tb4 off
  tb4 localize [map_yaml]
  tb4 map
  tb4 map save
  tb4 joy
  tb4 teleop
  tb4 nav2
  tb4 nav2_diag
  tb4 alive
  tb4 viz
  tb4 viz lite
  tb4 yolo
  tb4 yolo viz
  tb4 fusion
  tb4 fusion viz
  tb4 rgb_cam_rate
  tb4 bbox_rate
  tb4 depth_cam_rate
  tb4 robot_depth_cam_rate
  tb4 pointcloud_topic
  tb4 cam_info_topic
  tb4 obstacles
  tb4 battery
  tb4 clicked_point
  tb4 scan_rate
  tb4 reverse_test
  tb4 cat <remote_file_path>
  tb4 scp
  tb4 square [side_m] [speed_mps]

Examples:
  tb4 undock
  tb4 fwd 0.508 0.08
  tb4 back 0.25 0.08
  tb4 turn 90 1.0
  tb4 turn -90 1.0
  tb4 stop
  tb4 stop svc
  tb4 estop on
  tb4 estop off
  tb4 start svc
  tb4 restart
  tb4 dock
  tb4 square 0.5 0.08
  tb4 reboot create3
  tb4 status
  tb4 login
  tb4 off
  tb4 localize
  tb4 map
  tb4 map save
  tb4 joy
  tb4 teleop
  tb4 nav2
  tb4 nav2_diag
  tb4 viz
  tb4 viz lite
  tb4 yolo
  tb4 yolo viz
  tb4 fusion
  tb4 fusion viz
  tb4 rgb_cam_rate
  tb4 bbox_rate
  tb4 depth_cam_rate
  tb4 robot_depth_cam_rate
  tb4 pointcloud_topic
  tb4 cam_info_topic
  tb4 obstacles
  tb4 battery
  tb4 clicked_point
  tb4 scan_rate
  tb4 reverse_test
  tb4 cat /opt/ros/jazzy/share/turtlebot4_bringup/config/oakd_pro.yaml
  tb4 scp

Setup: 
  mkdir -p ~/bin
  cp ~/turtlebot4_ws/src/turtlebot4/turtlebot4_navigation/config/tb4 ~/bin/tb4
  chmod +x ~/bin/tb4
  echo 'export PATH="$HOME/bin:$PATH"' >> ~/.bashrc
  source ~/.bashrc

EOF
}

dock_cmd() {
  ros2 action send_goal /dock irobot_create_msgs/action/Dock
}

undock_cmd() {
  ros2 action send_goal /undock irobot_create_msgs/action/Undock
}

fwd_cmd() {
  local dist="${1:-0.5}"
  local speed="${2:-0.1}"
  if [[ "$speed" == -* ]]; then
    speed="${speed#-}"
  fi
  echo "Driving forward: distance=${dist} m, speed=${speed} m/s"
  ros2 action send_goal /drive_distance irobot_create_msgs/action/DriveDistance \
    "{distance: $dist, max_translation_speed: $speed}"
}

back_cmd() {
  local dist="${1:-0.5}"
  local speed="${2:-0.1}"
  if [[ "$speed" == -* ]]; then
    speed="${speed#-}"
  fi
  echo "Driving backward: distance=${dist} m, speed=${speed} m/s"
  ros2 action send_goal /drive_distance irobot_create_msgs/action/DriveDistance \
    "{distance: -$dist, max_translation_speed: $speed}"
}

turn_cmd() {
  local deg="${1:-90}"
  local speed="${2:-1.0}"
  local rad
  need_cmd bc
  rad="$(deg_to_rad "$deg")"
  echo "Turning: degrees=${deg}, radians=${rad}, speed=${speed}"
  ros2 action send_goal /rotate_angle irobot_create_msgs/action/RotateAngle \
    "{angle: $rad, max_rotation_speed: $speed}"
}

stop_cmd() {
  ros2 topic pub --once /cmd_vel geometry_msgs/msg/TwistStamped \
    "{header: {frame_id: 'base_link'}, twist: {linear: {x: 0.0, y: 0.0, z: 0.0}, angular: {x: 0.0, y: 0.0, z: 0.0}}}"
}

estop_cmd() {
  case "${1:-}" in
    on)
      ros2 service call /e_stop irobot_create_msgs/srv/EStop "{e_stop_on: true}"
      ;;
    off)
      ros2 service call /e_stop irobot_create_msgs/srv/EStop "{e_stop_on: false}"
      ;;
    *)
      echo "Usage: tb4 estop on|off"
      exit 1
      ;;
  esac
}

stop_svc_cmd() {
  echo "Stopping turtlebot4 service..."
  ssh -t ubuntu@turtlebot4 'sudo systemctl stop turtlebot4.service'
}

start_svc_cmd() {
  ssh -t ubuntu@turtlebot4 'sudo systemctl start turtlebot4.service'
}

restart_cmd() {
  ssh -t ubuntu@turtlebot4 'sudo systemctl restart turtlebot4.service'
}

reboot_create3_cmd() {
  local sock="/tmp/tb4_create3_${$}.sock"
  # Use a temporary local tunnel to reach Create3 web API via turtlebot4.
  ssh -f -N -M -S "$sock" -L 8080:192.168.186.2:80 ubuntu@turtlebot4
  curl -X POST http://localhost:8080/api/reboot
  ssh -S "$sock" -O exit ubuntu@turtlebot4 >/dev/null 2>&1 || true
}

status_cmd() {
  ssh -t ubuntu@turtlebot4 'systemctl status turtlebot4.service'
}

login_cmd() {
  ssh ubuntu@turtlebot4
}

off_cmd() {
  ros2 service call /robot_power irobot_create_msgs/srv/RobotPower "{}"
}

localize_cmd() {
  local map="${1:-$HOME/turtlebot4_ws/map_101.yaml}"
  ros2 launch turtlebot4_navigation localization.launch.py map:="$map"
}

map_cmd() {
  ros2 launch turtlebot4_navigation slam.launch.py params:=/home/qd/turtlebot4_ws/src/turtlebot4/turtlebot4_navigation/config/slam.yaml
}

map_save_cmd() {
  ros2 run nav2_map_server map_saver_cli -f /home/qd/turtlebot4_ws/map_101 --ros-args -p map_subscribe_transient_local:=true -r __ns:=/
}

joystick_cmd() {
  ros2 run joy_linux joy_linux_node --ros-args --params-file ~/bin/joy_linux.yaml
}

teleop_cmd() {
  ros2 run teleop_twist_joy teleop_node --ros-args --params-file ~/bin/teleop_ps4.yaml
}

wait_for_tf_cmd() {
  local from_frame="$1"
  local to_frame="$2"
  local timeout_s="${3:-30}"
  local deadline=$((SECONDS + timeout_s))

  while (( SECONDS < deadline )); do
    if timeout 2 ros2 run tf2_ros tf2_echo "$from_frame" "$to_frame" 2>/dev/null | grep -q "Translation:"; then
      return 0
    fi
    sleep 1
  done

  return 1
}

nav2_cmd() {
  local params_file="$HOME/turtlebot4_ws/src/turtlebot4/turtlebot4_navigation/config/nav2.yaml"
  ros2 launch turtlebot4_navigation nav2.launch.py params_file:="$HOME/turtlebot4_ws/src/turtlebot4/turtlebot4_navigation/config/nav2.yaml"
}

alive_cmd() {
  ros2 launch tb4_perception tf_keepalive.launch.py "$@"
}

nav2_diag_cmd() {
  echo "=== Nav2 motion diagnostics (run while a goal is active) ==="

  echo
  echo "[1/6] Checking command topics"
  ros2 topic list | grep -E '^/cmd_vel_nav$|^/cmd_vel_smoothed$|^/cmd_vel_stamped$|^/cmd_vel$' || true

  echo
  echo "[2/6] Command topic type / publisher count"
  ros2 topic info /cmd_vel || true
  ros2 topic info /cmd_vel_nav || true
  ros2 topic info /cmd_vel_smoothed || true
  ros2 topic info /cmd_vel_stamped || true

  echo
  echo "[3/6] Sample command from controller path"
  timeout 4 ros2 topic echo /cmd_vel --once || true
  timeout 4 ros2 topic echo /cmd_vel_nav --once || true
  timeout 4 ros2 topic echo /cmd_vel_smoothed --once || true
  timeout 4 ros2 topic echo /cmd_vel_stamped --once || true

  echo
  echo "[4/6] Collision monitor state"
  timeout 4 ros2 topic echo /collision_monitor_state --once || true

  echo
  echo "[5/6] Wheel / stop state"
  timeout 4 ros2 topic echo /wheel_status --once || true
  timeout 4 ros2 topic echo /stop_status --once || true

  echo
  echo "[6/6] E-stop service availability"
  ros2 service list | grep -E '^/e_stop$' || true
}

viz_cmd() {
  ros2 launch turtlebot4_viz view_navigation.launch.py
}

viz_lite_cmd() {
  local rviz_config="$HOME/turtlebot4_ws/src/turtlebot4_desktop/turtlebot4_viz/rviz/navigation_lite.rviz"
  ros2 run rviz2 rviz2 -d "$rviz_config"
}


yolo_cmd() {
  if [ "${1:-}" = "viz" ]; then
    ros2 launch tb4_perception yolo_detector.launch.py publish_visualisation:=true
  else
    ros2 launch tb4_perception yolo_detector.launch.py publish_visualisation:=false
  fi
}

fusion_cmd() {
  local params_file="$HOME/turtlebot4_ws/src/tb4_perception_integration/config/fusion_params.yaml"
  if [ "${1:-}" = "viz" ]; then
    ros2 launch tb4_perception_integration perception_integration.launch.py params_file:="$params_file" publish_debug_markers:=true
  else
    ros2 launch tb4_perception_integration perception_integration.launch.py params_file:="$params_file"
  fi
}

rgb_cam_rate_cmd() {
  timeout 8 ros2 topic hz /oakd/rgb/preview/image_raw --window 10
}

bbox_rate_cmd() {
  timeout 8 ros2 topic hz /detections --window 10
}

depth_cam_rate_cmd() {
  timeout 8 ros2 topic hz /oakd/stereo/image_raw --window 10
}

robot_depth_cam_rate_cmd() {
  ssh -t ubuntu@turtlebot4 "export RMW_IMPLEMENTATION=rmw_fastrtps_cpp && export FASTRTPS_DEFAULT_PROFILES_FILE=/etc/turtlebot4/fastdds_rpi.xml && source /etc/turtlebot4/setup.bash && timeout 30 ros2 topic hz /oakd/stereo/image_raw --window 10 2>&1"
}

pointcloud_topic_cmd() {
  timeout 8 ros2 topic hz /oakd/stereo/points --window 10
}

cam_info_topic_cmd() {
  timeout 8 ros2 topic hz /oakd/stereo/camera_info --window 10
}

obstacles_cmd() {
  timeout 8 ros2 topic hz /semantic_obstacles --window 10
}

battery_cmd() {
  ros2 topic echo /battery_state --once 2>&1 | head -10
}

clicked_point_cmd() {
  ros2 topic echo /clicked_point
}

scan_rate_cmd() {
  timeout 8 ros2 topic hz /scan --window 10
  ros2 topic echo /scan --once
}

reverse_test_cmd() {
  echo "-- Reverse test (0.8 m @ 0.1 m/s) --"
  ros2 action send_goal /drive_distance irobot_create_msgs/action/DriveDistance "{distance: -0.8, max_translation_speed: 0.1}"
}

cat_cmd() {
  local file="$1"
  if [ -z "$file" ]; then
    echo "Error: no file path specified."
    echo "Usage: tb4 cat <remote_file_path>"
    exit 1
  fi
  ssh -t ubuntu@turtlebot4 "cat '$file'"
}

scp_cmd() {
  scp "$HOME/turtlebot4_ws/src/turtlebot4/turtlebot4_navigation/config/tb4" ubuntu@turtlebot4:~/bin/tb4
  scp "$HOME/turtlebot4_ws/src/turtlebot4/turtlebot4_navigation/config/joy_linux.yaml" ubuntu@turtlebot4:~/bin/
  scp "$HOME/turtlebot4_ws/src/turtlebot4/turtlebot4_navigation/config/teleop_ps4.yaml" ubuntu@turtlebot4:~/bin/
}

square_cmd() {
  local side="${1:-0.5}"
  local speed="${2:-0.1}"
  local i
  for i in 1 2 3 4; do
    fwd_cmd "$side" "$speed"
    turn_cmd 90 1.0
  done
}

case "${1:-}" in
  dock)
    shift
    dock_cmd "$@"
    ;;
  undock)
    shift
    undock_cmd "$@"
    ;;
  fwd)
    shift
    fwd_cmd "$@"
    ;;
  back)
    shift
    back_cmd "$@"
    ;;
  turn)
    shift
    turn_cmd "$@"
    ;;
  stop)
    shift
    case "${1:-}" in
      svc) shift; stop_svc_cmd "$@" ;;
      *) stop_cmd "$@" ;;
    esac
    ;;
  estop)
    shift
    estop_cmd "$@"
    ;;
  start)
    shift
    case "${1:-}" in
      svc) shift; start_svc_cmd "$@" ;;
      *) echo "Unknown start subcommand: ${1:-}"; echo "Usage: tb4 start svc"; exit 1 ;;
    esac
    ;;
  restart)
    shift
    restart_cmd "$@"
    ;;
  reboot)
    shift
    case "${1:-}" in
      create3)
        shift
        reboot_create3_cmd "$@"
        ;;
      *)
        echo "Unknown reboot subcommand: ${1:-}"
        echo "Usage: tb4 reboot create3"
        exit 1
        ;;
    esac
    ;;
  login)
    shift
    login_cmd "$@"
    ;;
  status)
    shift
    status_cmd "$@"
    ;;
  off)
    shift
    off_cmd "$@"
    ;;
  localize)
    shift
    localize_cmd "$@"
    ;;
  map)
    shift
    case "${1:-}" in
      save)
        shift
        map_save_cmd "$@"
        ;;
      "")
        map_cmd "$@"
        ;;
      *)
        echo "Unknown map subcommand: ${1:-}"
        echo "Usage: tb4 map [save]"
        exit 1
        ;;
    esac
    ;;
  joy)
    shift
    joystick_cmd "$@"
    ;;
  teleop)
    shift
    teleop_cmd "$@"
    ;;
  nav2)
    shift
    nav2_cmd "$@"
    ;;
  nav2_diag)
    shift
    nav2_diag_cmd "$@"
    ;;
  alive)
    shift
    alive_cmd "$@"
    ;;
  viz)
    shift
    case "${1:-}" in
      lite)
        shift
        viz_lite_cmd "$@"
        ;;
      "")
        viz_cmd "$@"
        ;;
      *)
        echo "Unknown viz subcommand: ${1:-}"
        echo "Usage: tb4 viz [lite]"
        exit 1
        ;;
    esac
    ;;
  yolo)
    shift
    yolo_cmd "$@"
    ;;
  fusion)
    shift
    fusion_cmd "$@"
    ;;
  rgb_cam_rate)
    shift
    rgb_cam_rate_cmd "$@"
    ;;
  bbox_rate)
    shift
    bbox_rate_cmd "$@"
    ;;
  depth_cam_rate)
    shift
    depth_cam_rate_cmd "$@"
    ;;
  robot_depth_cam_rate)
    shift
    robot_depth_cam_rate_cmd "$@"
    ;;
  pointcloud_topic)
    shift
    pointcloud_topic_cmd "$@"
    ;;
  cam_info_topic)
    shift
    cam_info_topic_cmd "$@"
    ;;
  obstacles)
    shift
    obstacles_cmd "$@"
    ;;
  battery)
    shift
    battery_cmd "$@"
    ;;
  clicked_point)
    shift
    clicked_point_cmd "$@"
    ;;
  scan_rate)
    shift
    scan_rate_cmd "$@"
    ;;
  reverse_test)
    shift
    reverse_test_cmd "$@"
    ;;
  cat)
    shift
    cat_cmd "$@"
    ;;
  scp)
    shift
    scp_cmd "$@"
    ;;
  square)
    shift
    square_cmd "$@"
    ;;
  ""|-h|--help|help)
    usage
    ;;
  *)
    echo "Unknown command: $1"
    echo
    usage
    exit 1
    ;;
esac